# Development Configuration

ENV=development
PORT=8080

# Database Configuration (Postgres container details)
DATABASE_URL=postgres://your_db_user:your_db_password@localhost:5432/your_db_name?sslmode=disable

# JWT Session Configuration
JWT_SECRET=your-32-character-jwt-signing-key-placeholder
JWT_EXPIRY=24h
COOKIE_SECURE=false

# Initial admin account (created on first boot if it does not exist)
# ALWAYS override these in production – never use the default values.
ADMIN_USERNAME=root
ADMIN_PASSWORD=change-me-in-production

# NATS Configuration
NATS_URL=nats://localhost:4222

# MediaMTX Configuration
MEDIAMTX_API_URL=http://localhost:9997

# MinIO & Video Tiering Configuration
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadminpassword
MINIO_USE_SSL=false
MINIO_BUCKET=wardis-video-recordings
VIDEO_TIERING_INTERVAL=1h
VIDEO_TIERING_AGE_DAYS=7
RECORDINGS_LOCAL_DIR=./data/recordings
